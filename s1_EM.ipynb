      "source": [
        "class Point:\n",
        "  def __init__(self,x,y):\n",
        "    self.x = x\n",
        "    self.y = y\n",
        "  def __str__(self):\n",
        "    return f\"P<{self.x}, {self.y}>\"\n",
        "\n",
        "p1=Point(1,2)\n",
        "p2=Point(3,4)\n",
        "\n",
        "print(p1.x,p1.y)\n",
        "print(p2.x,p2.y)\n",
        "print(p1,p2)"
      ]
